get_container_status_by_hash() {
    local unique_hash=$1
    local container_name="cuda-project-${unique_hash}-container"

    if docker ps -a --format "table {{.Names}}\t{{.Status}}" | grep -q "$container_name"; then
        local status=$(docker ps -a --format "table {{.Names}}\t{{.Status}}" | grep "$container_name" | awk '{print $2}')
        if [[ "$status" == Up* ]]; then
            echo "running"
        else
            echo "stopped"
        fi
    else
        echo "nonexistent"
    fi
}

find_env_configs_by_name() {
    local target_name=$1

    for config_file in "$GLOBAL_CONFIG_DIR"/*.conf; do
        if [ ! -f "$config_file" ]; then
            continue
        fi

        local env_name=$(read_config_value "$config_file" "ENV_NAME")
        local status=$(read_config_value "$config_file" "STATUS")
        local project_path=$(read_config_value "$config_file" "PROJECT_PATH")

        if [ "$env_name" = "$target_name" ] && [ "$status" != "deleted" ] && [ -d "$project_path/.cudo" ]; then
            echo "$config_file"
        fi
    done
}

select_env_interactive() {
    SELECTED_ENV_CONFIG=""
    local configs=()
    local index=1

    echo "Available CUDA environments:"
    printf "%-4s %-24s %-14s %s\n" "NO." "NAME" "STATUS" "PATH"

    for config_file in "$GLOBAL_CONFIG_DIR"/*.conf; do
        if [ ! -f "$config_file" ]; then
            continue
        fi

        local env_name=$(read_config_value "$config_file" "ENV_NAME")
        local status=$(read_config_value "$config_file" "STATUS")
        local project_path=$(read_config_value "$config_file" "PROJECT_PATH")
        local unique_hash=$(read_config_value "$config_file" "UNIQUE_HASH")

        if [ "$status" = "deleted" ] || [ ! -d "$project_path/.cudo" ]; then
            continue
        fi

        local container_status=$(get_container_status_by_hash "$unique_hash")
        configs+=("$config_file")
        printf "%-4s %-24s %-14s %s\n" "$index" "$env_name" "$container_status" "$project_path"
        index=$((index + 1))
    done

    if [ ${#configs[@]} -eq 0 ]; then
        log_error "No active Cudo environments found"
        return 1
    fi

    local selection
    echo
    read -r -p "Select environment number: " selection

    if ! [[ "$selection" =~ ^[0-9]+$ ]] || [ "$selection" -lt 1 ] || [ "$selection" -gt ${#configs[@]} ]; then
        log_error "Invalid selection: $selection"
        return 1
    fi

    SELECTED_ENV_CONFIG="${configs[$((selection - 1))]}"
    return 0
}

docker_exec_container() {
    local container_name=$1
    shift

    if [ $# -eq 0 ]; then
        set -- bash
    fi

    if [ -t 0 ] && [ -t 1 ]; then
        docker exec -it "$container_name" "$@"
    else
        docker exec -i "$container_name" "$@"
    fi
}

enter_global_config() {
    local config_file=$1
    shift

    local env_name=$(read_config_value "$config_file" "ENV_NAME")
    local project_path=$(read_config_value "$config_file" "PROJECT_PATH")
    local image_name=$(read_config_value "$config_file" "IMAGE_NAME")
    local unique_hash=$(read_config_value "$config_file" "UNIQUE_HASH")
    local project_config_dir="$project_path/.cudo"
    local container_name="cuda-project-${unique_hash}-container"

    if [ -z "$env_name" ] || [ -z "$project_path" ] || [ -z "$image_name" ] || [ -z "$unique_hash" ]; then
        log_error "Environment configuration is incomplete: $config_file"
        exit 1
    fi

    if [ ! -d "$project_config_dir" ] || [ ! -f "$project_config_dir/docker-compose.yml" ]; then
        log_error "Environment '$env_name' is missing its .cudo configuration"
        log_error "Project path: $project_path"
        exit 1
    fi

    if ! check_image_exists "$image_name"; then
        log_error "=========================================="
        log_error "Environment is broken!"
        log_error "=========================================="
        log_error "Image '$image_name' does not exist."
        log_error ""
        log_error "To fix this, rebuild the environment:"
        log_error "  cd \"$project_path\" && cudo build"
        log_error "=========================================="
        exit 1
    fi

    local status=$(get_container_status_by_hash "$unique_hash")
    local check_ssh_port=true
    if [ "$status" = "running" ] && [ -z "$SSH_OPTION_PORT" ]; then
        check_ssh_port=false
    fi

    SSH_RUNTIME_CONFIGURED=false
    if ! update_ssh_runtime_config "$project_path" "$image_name" "$unique_hash" "$config_file" "$SSH_OPTION_PORT" "$SSH_OPTION_PASSWORD" "$SSH_OPTION_PASSWORD_PROVIDED" "$check_ssh_port"; then
        exit 1
    fi

    case $status in
        "running")
            log_info "Entering environment: $env_name"
            configure_running_container_ssh "$container_name"
            docker_exec_container "$container_name" "$@"
            ;;
        "stopped"|"nonexistent")
            log_info "Starting environment: $env_name"
            cd "$project_config_dir"
            docker_compose_cmd up -d
            sleep 2
            configure_running_container_ssh "$container_name"
            docker_exec_container "$container_name" "$@"
            ;;
    esac
}

enter_command() {
    local target_name=""
    local exec_args=()
    SSH_OPTION_PORT=""
    SSH_OPTION_PASSWORD=""
    SSH_OPTION_PASSWORD_PROVIDED=false

    if [ $# -gt 0 ]; then
        while [[ $# -gt 0 ]]; do
            case $1 in
                --ssh-port)
                    if [ $# -lt 2 ]; then
                        log_error "Missing value for --ssh-port"
                        exit 1
                    fi
                    SSH_OPTION_PORT="$2"
                    if ! validate_ssh_port "$SSH_OPTION_PORT"; then
                        exit 1
                    fi
                    shift 2
                    ;;
                --ssh-password)
                    if [ $# -lt 2 ]; then
                        log_error "Missing value for --ssh-password"
                        exit 1
                    fi
                    SSH_OPTION_PASSWORD="$2"
                    SSH_OPTION_PASSWORD_PROVIDED=true
                    shift 2
                    ;;
                --)
                    shift
                    exec_args=("$@")
                    break
                    ;;
                *)
                    if [ -z "$target_name" ]; then
                        target_name="$1"
                        shift
                    else
                        log_error "Unexpected argument: $1"
                        log_error "Use '--' before commands, for example: cudo enter $target_name -- nvidia-smi"
                        exit 1
                    fi
                    ;;
            esac
        done
    fi

    local selected_config=""
    if [ -n "$target_name" ]; then
        if ! validate_env_name "$target_name"; then
            exit 1
        fi

        local matches=()
        while IFS= read -r match; do
            matches+=("$match")
        done < <(find_env_configs_by_name "$target_name")

        if [ ${#matches[@]} -eq 0 ]; then
            log_error "Cudo environment not found: $target_name"
            log_info "Run 'cudo list' to see available environments."
            exit 1
        fi

        if [ ${#matches[@]} -gt 1 ]; then
            log_error "Multiple environments match '$target_name'. Run 'cudo list' and clean up duplicates."
            exit 1
        fi

        selected_config="${matches[0]}"
    else
        if ! select_env_interactive; then
            exit 1
        fi
        selected_config="$SELECTED_ENV_CONFIG"
    fi

    enter_global_config "$selected_config" "${exec_args[@]}"
}

rename_command() {
    if [ $# -ne 2 ]; then
        log_error "Usage: cudo rename <origin_name> <new_name>"
        exit 1
    fi

    local origin_name=$1
    local new_name=$2

    if ! validate_env_name "$origin_name"; then
        exit 1
    fi
    if ! validate_env_name "$new_name"; then
        exit 1
    fi

    local matches=()
    while IFS= read -r match; do
        matches+=("$match")
    done < <(find_env_configs_by_name "$origin_name")

    if [ ${#matches[@]} -eq 0 ]; then
        log_error "Cudo environment not found: $origin_name"
        log_info "Run 'cudo list' to see available environments."
        exit 1
    fi

    if [ ${#matches[@]} -gt 1 ]; then
        log_error "Multiple environments match '$origin_name'. Run 'cudo list' and clean up duplicates."
        exit 1
    fi

    local config_file="${matches[0]}"
    if [ "$origin_name" = "$new_name" ]; then
        log_info "Environment name is already '$new_name'"
        return 0
    fi

    if env_name_exists "$new_name" "$config_file"; then
        log_error "Environment name already exists: $new_name"
        log_error "Choose a different name or remove the existing environment first."
        exit 1
    fi

    local project_path=$(read_config_value "$config_file" "PROJECT_PATH")
    set_config_value "$config_file" "ENV_NAME" "$new_name"

    if [ -n "$project_path" ] && [ -f "$project_path/.cudo/config" ]; then
        set_config_value "$project_path/.cudo/config" "ENV_NAME" "$new_name"
    fi

    log_success "Renamed environment '$origin_name' to '$new_name'"
}

