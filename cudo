#!/bin/bash

# Cudo - CUDA Development Environment Manager
# Usage: cudo [command] [options]

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
# 如果 SCRIPT_DIR 指向的是主脚本所在目录，那么 Python 脚本应该在 scripts 子目录中
PYTHON_SCRIPT_DIR="$SCRIPT_DIR/scripts"
PROJECT_ROOT="$(pwd)"

# Default Config
DEFAULT_CUDA_VERSION="12.4.0"
DEFAULT_UBUNTU_VERSION="20.04"
DEFAULT_WITH_TOOLKIT="false"
DEFAULT_PYTHON_VERSION="3.10"
DEFAULT_SSH_ENABLED="true"
# 注意：实际的镜像名称会在 build 时加上 UNIQUE_HASH
DEFAULT_IMAGE_NAME_BASE="cuda-project-$(basename "$PROJECT_ROOT" | tr '[:upper:]' '[:lower:]')"

CONFIG_DIR="$PROJECT_ROOT/.cudo"

CONFIG_FILE="$CONFIG_DIR/config"
DOCKERFILE="$CONFIG_DIR/Dockerfile"
DOCKER_COMPOSE_FILE="$CONFIG_DIR/docker-compose.yml"
SSH_ENTRYPOINT_FILE="$CONFIG_DIR/cudo-entrypoint.sh"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Log Function
log_info() { echo -e "${BLUE}$1${NC}"; }
log_success() { echo -e "${GREEN} $1${NC}"; }
log_warning() { echo -e "${YELLOW}$1${NC}"; }
log_error() { echo -e "${RED}$1${NC}"; }

read_config_value() {
    local config_file=$1
    local key=$2
    grep -m1 "^${key}=" "$config_file" 2>/dev/null | cut -d'=' -f2- | sed 's/^"//; s/"$//'
}

set_config_value() {
    local config_file=$1
    local key=$2
    local value=$3
    local tmp_file="${config_file}.tmp.$$"

    if grep -q "^${key}=" "$config_file" 2>/dev/null; then
        awk -v key="$key" -v value="$value" '
            BEGIN { prefix = key "=" }
            index($0, prefix) == 1 { print prefix value; next }
            { print }
        ' "$config_file" > "$tmp_file" && mv "$tmp_file" "$config_file"
    else
        echo "${key}=${value}" >> "$config_file"
    fi
}

remove_config_value() {
    local config_file=$1
    local key=$2
    local tmp_file="${config_file}.tmp.$$"

    if [ ! -f "$config_file" ]; then
        return 0
    fi

    awk -v key="$key" '
        BEGIN { prefix = key "=" }
        index($0, prefix) != 1 { print }
    ' "$config_file" > "$tmp_file" && mv "$tmp_file" "$config_file"
}

normalize_env_name() {
    local raw_name=$1
    local env_name

    env_name=$(printf '%s' "$raw_name" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9._-]/-/g; s/^[._-]*//; s/[._-]*$//')
    if [ -z "$env_name" ]; then
        env_name="cudo-env"
    fi

    echo "$env_name"
}

validate_env_name() {
    local env_name=$1

    if ! [[ "$env_name" =~ ^[a-z0-9._-]+$ ]]; then
        log_error "Invalid environment name: '$env_name'"
        log_error "Environment names can only contain lowercase letters, numbers, dots, hyphens, and underscores"
        return 1
    fi

    if [[ "$env_name" =~ ^[._-] ]]; then
        log_error "Invalid environment name: '$env_name'"
        log_error "Environment names cannot start with a dot, hyphen, or underscore"
        return 1
    fi

    if [[ "$env_name" =~ [._-]$ ]]; then
        log_error "Invalid environment name: '$env_name'"
        log_error "Environment names cannot end with a dot, hyphen, or underscore"
        return 1
    fi

    if [[ "$env_name" =~ \.\. ]]; then
        log_error "Invalid environment name: '$env_name'"
        log_error "Environment names cannot contain consecutive dots"
        return 1
    fi

    if [ ${#env_name} -gt 128 ]; then
        log_error "Invalid environment name: '$env_name'"
        log_error "Environment names cannot exceed 128 characters"
        return 1
    fi

    return 0
}

env_name_exists() {
    local env_name=$1
    local exclude_config=${2:-}

    for config_file in "$GLOBAL_CONFIG_DIR"/*.conf; do
        if [ ! -f "$config_file" ]; then
            continue
        fi
        if [ -n "$exclude_config" ] && [ "$config_file" = "$exclude_config" ]; then
            continue
        fi

        local existing_env_name=$(read_config_value "$config_file" "ENV_NAME")
        local status=$(read_config_value "$config_file" "STATUS")
        if [ "$existing_env_name" = "$env_name" ] && [ "$status" != "deleted" ]; then
            return 0
        fi
    done

    return 1
}

generate_unique_env_name() {
    local base_name=$1
    local exclude_config=${2:-}
    local candidate=$base_name
    local suffix=2

    while env_name_exists "$candidate" "$exclude_config"; do
        candidate="${base_name}-${suffix}"
        suffix=$((suffix + 1))
    done

    echo "$candidate"
}

get_global_config_for_hash() {
    local unique_hash=$1

    if [ -z "$unique_hash" ]; then
        return 1
    fi

    find "$GLOBAL_CONFIG_DIR" -name "*.conf" -exec grep -l "^UNIQUE_HASH=${unique_hash}$" {} \; 2>/dev/null | head -1
}

ensure_env_name() {
    local default_base
    local current_global_config

    if [ -z "$ENV_NAME" ]; then
        default_base=$(normalize_env_name "$(basename "$PROJECT_ROOT")")
        current_global_config=$(get_global_config_for_hash "$UNIQUE_HASH")
        ENV_NAME=$(generate_unique_env_name "$default_base" "$current_global_config")
        if [ -f "$CONFIG_FILE" ]; then
            set_config_value "$CONFIG_FILE" "ENV_NAME" "$ENV_NAME"
        fi
    fi
}

sync_global_env_names() {
    if [ "$GLOBAL_CONFIG_WRITABLE" != "true" ]; then
        return 0
    fi

    local config_file

    for config_file in "$GLOBAL_CONFIG_DIR"/*.conf; do
        if [ ! -f "$config_file" ]; then
            continue
        fi

        local env_name=$(read_config_value "$config_file" "ENV_NAME")
        if [ -n "$env_name" ]; then
            continue
        fi

        local project_name=$(read_config_value "$config_file" "PROJECT_NAME")
        local project_path=$(read_config_value "$config_file" "PROJECT_PATH")
        local base_name=$(normalize_env_name "${project_name:-cudo-env}")
        local unique_name=$(generate_unique_env_name "$base_name" "$config_file")

        set_config_value "$config_file" "ENV_NAME" "$unique_name"
        if [ -n "$project_path" ] && [ -f "$project_path/.cudo/config" ]; then
            set_config_value "$project_path/.cudo/config" "ENV_NAME" "$unique_name"
        fi
    done
}


# Global configuration directory (stores all project information)
# Use system-wide directory for multi-user support. Tests can override this.
GLOBAL_CONFIG_DIR="${CUDO_GLOBAL_CONFIG_DIR:-/var/lib/cudo-global}"
GLOBAL_CONFIG_WRITABLE=false
if [ -d "$GLOBAL_CONFIG_DIR" ] && [ -w "$GLOBAL_CONFIG_DIR" ]; then
    GLOBAL_CONFIG_WRITABLE=true
fi

ensure_global_config_writable() {
    if [ "$GLOBAL_CONFIG_WRITABLE" = "true" ]; then
        return 0
    fi

    mkdir -p "$GLOBAL_CONFIG_DIR" 2>/dev/null || true
    if [ -d "$GLOBAL_CONFIG_DIR" ] && [ -w "$GLOBAL_CONFIG_DIR" ]; then
        GLOBAL_CONFIG_WRITABLE=true
        return 0
    fi

    log_error "Global configuration directory $GLOBAL_CONFIG_DIR is not writable"
    log_error "Please ensure the directory exists and has proper permissions:"
    log_error "  sudo mkdir -p $GLOBAL_CONFIG_DIR"
    log_error "  sudo chmod 777 $GLOBAL_CONFIG_DIR"
    return 1
}

save_config() {
    # 不在这里生成哈希，哈希应该在 build 时或检测到拷贝时生成
    # 如果 UNIQUE_HASH 为空，说明配置有问题
    if [ -z "$UNIQUE_HASH" ]; then
        log_error "UNIQUE_HASH is not set. This should not happen."
        exit 1
    fi

    cat > "$CONFIG_FILE" << EOF
CUDA_VERSION=$CUDA_VERSION
UBUNTU_VERSION=$UBUNTU_VERSION
WITH_TOOLKIT=$WITH_TOOLKIT
PYTHON_VERSION=$PYTHON_VERSION
IMAGE_NAME=$IMAGE_NAME
CUDA_VARIANT=$CUDA_VARIANT
UNIQUE_HASH=$UNIQUE_HASH
ENV_NAME=$ENV_NAME
SSH_ENABLED=$SSH_ENABLED
SSH_PORT=$SSH_PORT
SSH_USER=$SSH_USER
SSH_PASSWORD_HASH_B64=$SSH_PASSWORD_HASH_B64
EOF
    log_success "Configuration saved"
}

save_to_global() {
    if ! ensure_global_config_writable; then
        exit 1
    fi

    local project_name=$(basename "$PROJECT_ROOT")
    local unique_hash=$UNIQUE_HASH
    local unique_id="${project_name}-${unique_hash}"
    local global_config_file="$GLOBAL_CONFIG_DIR/${unique_id}.conf"

    # 获取当前项目目录的 inode
    local current_inode=$(stat -c '%i' "$PROJECT_ROOT" 2>/dev/null || stat -f '%i' "$PROJECT_ROOT" 2>/dev/null)

    # 检查是否已存在相同路径的配置
    local existing_config_by_path=$(find "$GLOBAL_CONFIG_DIR" -name "*.conf" -exec grep -l "PROJECT_PATH=$PROJECT_ROOT$" {} \; 2>/dev/null | head -1)

    if [ -n "$existing_config_by_path" ]; then
        # 同一路径，只需更新配置，不删除
        log_info "Updating existing configuration for current path"
    fi

    # 检查是否已存在相同 unique_hash 的配置（但不同路径）
    local existing_config_by_hash=$(find "$GLOBAL_CONFIG_DIR" -name "*.conf" -exec grep -l "UNIQUE_HASH=$unique_hash$" {} \; 2>/dev/null | head -1)

    if [ -n "$existing_config_by_hash" ]; then
        # 获取原始项目路径
        local original_project_path=$(grep "PROJECT_PATH=" "$existing_config_by_hash" | cut -d'=' -f2-)

        if [ "$original_project_path" != "$PROJECT_ROOT" ]; then
            # 路径不同，需要判断是移动还是拷贝

            # 获取原始路径的 inode（如果路径仍然存在）
            local original_inode=""
            if [ -d "$original_project_path" ]; then
                original_inode=$(stat -c '%i' "$original_project_path" 2>/dev/null || stat -f '%i' "$original_project_path" 2>/dev/null)
            fi

            if [ -n "$original_inode" ] && [ "$original_inode" = "$current_inode" ]; then
                # inode 相同 → 这是移动操作
                log_info "Detected project move from $original_project_path to $PROJECT_ROOT"
                log_info "Updating configuration with new path, keeping hash: $unique_hash"
                # 删除旧配置文件
                rm -f "$existing_config_by_hash"
            elif [ -d "$original_project_path/.cudo" ]; then
                # 原始路径存在且 inode 不同 → 这是拷贝操作
                log_warning "=========================================="
                log_warning "Detected project copy!"
                log_warning "Original: $original_project_path"
                log_warning "Copy: $PROJECT_ROOT"
                log_warning "=========================================="

                # 生成新的唯一哈希
                UNIQUE_HASH=$(openssl rand -hex 4)
                unique_hash=$UNIQUE_HASH
                unique_id="${project_name}-${unique_hash}"
                global_config_file="$GLOBAL_CONFIG_DIR/${unique_id}.conf"

                # 更新镜像名称以包含新的哈希
                # 从旧的 IMAGE_NAME 中提取基础名称（去掉旧哈希）
                local old_hash=$(grep "UNIQUE_HASH=" "$existing_config_by_hash" | cut -d'=' -f2)
                local image_name_base="${IMAGE_NAME%-$old_hash}"
                IMAGE_NAME="${image_name_base}-${UNIQUE_HASH}"

                log_warning "Generated new unique hash: $unique_hash"
                log_warning "New image name: $IMAGE_NAME"
                log_warning ""
                log_warning "IMPORTANT: You must rebuild the image for this copied project!"
                log_warning "Run: cudo build"
                log_warning "=========================================="

                # 更新本地配置文件
                ENV_NAME=$(generate_unique_env_name "$(normalize_env_name "$ENV_NAME")")
                save_config
                log_success "Configuration saved with new hash and environment name: $ENV_NAME"

                # 重新生成 docker-compose.yml 文件以使用新的服务名和镜像名
                generate_docker_compose "$IMAGE_NAME"
                log_info "Updated docker-compose.yml with new service name and image name"
            else
                # 原始路径不存在 → 这是移动操作（原路径已删除）
                log_info "Original path no longer exists, treating as move operation"
                log_info "Updating configuration with new path, keeping hash: $unique_hash"
                # 删除旧配置文件
                rm -f "$existing_config_by_hash"
            fi
        fi
    fi

    ensure_env_name
    local current_env_config=$(get_global_config_for_hash "$unique_hash")
    if env_name_exists "$ENV_NAME" "$current_env_config"; then
        ENV_NAME=$(generate_unique_env_name "$(normalize_env_name "$ENV_NAME")" "$current_env_config")
        if [ -f "$CONFIG_FILE" ]; then
            set_config_value "$CONFIG_FILE" "ENV_NAME" "$ENV_NAME"
        fi
    fi

    cat > "$global_config_file" << EOF
PROJECT_NAME=$project_name
ENV_NAME=$ENV_NAME
PROJECT_PATH=$PROJECT_ROOT
CUDA_VERSION=$CUDA_VERSION
UBUNTU_VERSION=$UBUNTU_VERSION
WITH_TOOLKIT=$WITH_TOOLKIT
PYTHON_VERSION=$PYTHON_VERSION
IMAGE_NAME=$IMAGE_NAME
CUDA_VARIANT=$CUDA_VARIANT
SSH_ENABLED=$SSH_ENABLED
SSH_PORT=$SSH_PORT
SSH_USER=$SSH_USER
SSH_PASSWORD_HASH_B64=$SSH_PASSWORD_HASH_B64
CREATED_TIME="$(date '+%Y-%m-%d %H:%M:%S')"
LAST_UPDATED="$(date '+%Y-%m-%d %H:%M:%S')"
UNIQUE_HASH=$unique_hash
UNIQUE_ID=$unique_id
STATUS=active
EOF
    log_success "Configuration saved to global storage: $unique_id"
}

remove_from_global() {
    if [ "$GLOBAL_CONFIG_WRITABLE" != "true" ]; then
        return 0
    fi

    local unique_hash=$UNIQUE_HASH
    local project_name=$(basename "$PROJECT_ROOT")
    local unique_id="${project_name}-${unique_hash}"
    local global_config_file="$GLOBAL_CONFIG_DIR/${unique_id}.conf"

    if [ -f "$global_config_file" ]; then
        rm -f "$global_config_file"
        log_success "Removed from global storage: $unique_id"
    fi
}

# 检查并更新全局配置状态
update_global_status() {
    if [ "$GLOBAL_CONFIG_WRITABLE" != "true" ]; then
        return 0
    fi

    # 遍历所有全局配置文件
    for config_file in "$GLOBAL_CONFIG_DIR"/*.conf; do
        if [ -f "$config_file" ]; then
            local project_path=$(read_config_value "$config_file" "PROJECT_PATH")

            # 检查项目路径是否还存在容器配置文件夹
            local config_dir="$project_path/.cudo"
            if [ ! -d "$config_dir" ]; then
                # 标记为已删除或已移动
                set_config_value "$config_file" "STATUS" "deleted"
                set_config_value "$config_file" "LAST_UPDATED" "\"$(date '+%Y-%m-%d %H:%M:%S')\""
            else
                # 确保状态是 active
                set_config_value "$config_file" "STATUS" "active"
                set_config_value "$config_file" "LAST_UPDATED" "\"$(date '+%Y-%m-%d %H:%M:%S')\""
            fi
        fi
    done
}

# 清理已删除/移动的项目配置
cleanup_deleted_projects() {
    if ! ensure_global_config_writable; then
        return 1
    fi

    local deleted_count=0

    # 遍历所有全局配置文件
    for config_file in "$GLOBAL_CONFIG_DIR"/*.conf; do
        if [ -f "$config_file" ]; then
            local status=$(grep "STATUS=" "$config_file" | cut -d'=' -f2)

            if [ "$status" = "deleted" ]; then
                local project_name=$(grep "PROJECT_NAME=" "$config_file" | cut -d'=' -f2)
                local unique_id=$(grep "UNIQUE_ID=" "$config_file" | cut -d'=' -f2)

                rm -f "$config_file"
                deleted_count=$((deleted_count + 1))
                log_info "Removed deleted project: $unique_id"
            fi
        fi
    done

    if [ $deleted_count -eq 0 ]; then
        log_info "No deleted projects to clean up"
    else
        log_success "Cleaned up $deleted_count deleted project(s)"
    fi
}

# 清理旧的全局配置文件（基于项目名称的）
cleanup_old_global_configs() {
    if [ "$GLOBAL_CONFIG_WRITABLE" != "true" ]; then
        return 0
    fi

    local project_name=$(basename "$PROJECT_ROOT")
    local unique_hash=$UNIQUE_HASH
    local current_unique_id="${project_name}-${unique_hash}"

    # 查找所有相同项目名称的旧配置文件
    for old_config in "$GLOBAL_CONFIG_DIR/${project_name}.conf"*; do
        if [ -f "$old_config" ] && [[ "$old_config" != *"$current_unique_id.conf" ]]; then
            rm -f "$old_config"
            log_info "Cleaned up old global config: $(basename "$old_config")"
        fi
    done
}

# 加载配置
load_config() {
    if [ -f "$CONFIG_FILE" ]; then
        source "$CONFIG_FILE"
        # 如果配置中没有 UNIQUE_HASH，这是一个错误状态
        if [ -z "$UNIQUE_HASH" ]; then
            log_error "Configuration file is missing UNIQUE_HASH. Please rebuild the project."
            return 1
        fi
        SSH_ENABLED=${SSH_ENABLED:-$DEFAULT_SSH_ENABLED}
        SSH_PORT=${SSH_PORT:-}
        SSH_USER=${SSH_USER:-$(id -un)}
        SSH_PASSWORD_HASH_B64=${SSH_PASSWORD_HASH_B64:-}
        SSH_PASSWORD_B64=${SSH_PASSWORD_B64:-}
        ensure_env_name
        return 0
    else
        return 1
    fi
}

# 检查依赖
check_dependencies() {
    local missing=()

    if ! command -v docker &> /dev/null; then
        missing+=("docker")
    fi

    # Docker Compose: V2 (docker compose) 或 V1 (docker-compose) 其中一个即可
    local has_compose=false
    if command -v docker > /dev/null && docker compose version > /dev/null 2>&1; then
        has_compose=true
    elif command -v docker-compose > /dev/null; then
        has_compose=true
    fi

    if [ "$has_compose" = false ]; then
        missing+=("docker-compose")
    fi

    if ! command -v envsubst &> /dev/null; then
        missing+=("envsubst (gettext)")
    fi

    if ! command -v openssl &> /dev/null; then
        missing+=("openssl")
    fi

    if [ ${#missing[@]} -ne 0 ]; then
        log_error "Missing dependencies: ${missing[*]}"
        echo "Please install the following software:"
        for dep in "${missing[@]}"; do
            case $dep in
                "docker")
                    echo "  Docker: https://docs.docker.com/get-docker/"
                    ;;
                "docker-compose")
                    echo "  Docker Compose (V2 or V1): https://docs.docker.com/compose/install/"
                    ;;
                "envsubst (gettext)")
                    echo "  envsubst:"
                    echo "    Ubuntu/Debian: sudo apt-get install gettext"
                    echo "    CentOS/RHEL: sudo yum install gettext"
                    ;;
                "openssl")
                    echo "  OpenSSL:"
                    echo "    Ubuntu/Debian: sudo apt-get install openssl"
                    echo "    CentOS/RHEL: sudo yum install openssl"
                    ;;
            esac
        done
        exit 1
    fi
}

validate_ssh_port() {
    local port=$1

    if [ -z "$port" ]; then
        log_error "SSH port is required"
        return 1
    fi

    if ! [[ "$port" =~ ^[0-9]+$ ]]; then
        log_error "Invalid SSH port: '$port'"
        log_error "SSH port must be a number between 1 and 65535"
        return 1
    fi

    if [ "$port" -lt 1 ] || [ "$port" -gt 65535 ]; then
        log_error "Invalid SSH port: '$port'"
        log_error "SSH port must be between 1 and 65535"
        return 1
    fi

    return 0
}

ssh_port_in_use() {
    local port=$1

    if command -v ss > /dev/null 2>&1; then
        ss -H -ltn 2>/dev/null | awk -v suffix=":${port}" '$4 ~ suffix "$" { found=1 } END { exit !found }'
        return $?
    fi

    if command -v lsof > /dev/null 2>&1; then
        lsof -nP -iTCP:"$port" -sTCP:LISTEN > /dev/null 2>&1
        return $?
    fi

    if command -v netstat > /dev/null 2>&1; then
        netstat -an 2>/dev/null | awk -v port="$port" '
            tolower($1) ~ /^tcp/ && ($NF == "LISTEN" || $NF == "LISTENING") {
                if ($4 ~ ":" port "$" || $4 ~ "\\." port "$") found=1
            }
            END { exit !found }
        '
        return $?
    fi

    (echo > "/dev/tcp/127.0.0.1/$port") > /dev/null 2>&1
}

ensure_ssh_port_available() {
    local port=$1

    if ! validate_ssh_port "$port"; then
        return 1
    fi

    if ssh_port_in_use "$port"; then
        log_error "SSH port $port is already in use on the host"
        log_error "Choose another port or stop the process using this port first"
        return 1
    fi

    return 0
}

base64_encode_value() {
    printf '%s' "$1" | base64 | tr -d '\n'
}

base64_decode_value() {
    if base64 --help 2>&1 | grep -q -- '--decode'; then
        printf '%s' "$1" | base64 --decode
    elif base64 -d </dev/null >/dev/null 2>&1; then
        printf '%s' "$1" | base64 -d
    else
        printf '%s' "$1" | base64 -D
    fi
}

generate_ssh_password_hash_b64() {
    local password=$1
    local salt
    local password_hash

    if ! command -v openssl > /dev/null 2>&1; then
        log_error "openssl is required to hash SSH passwords"
        return 1
    fi

    salt=$(openssl rand -hex 8)
    password_hash=$(printf '%s\n' "$password" | openssl passwd -6 -stdin -salt "$salt")
    if [ -z "$password_hash" ]; then
        log_error "Failed to hash SSH password"
        return 1
    fi

    base64_encode_value "$password_hash"
}

ssh_password_is_configured() {
    [ -n "${SSH_PASSWORD_HASH_B64:-}" ] || [ -n "${SSH_PASSWORD_B64:-}" ]
}

password_hash_from_legacy_b64() {
    local legacy_b64=$1
    local legacy_password

    if [ -z "$legacy_b64" ]; then
        return 1
    fi

    legacy_password=$(base64_decode_value "$legacy_b64")
    generate_ssh_password_hash_b64 "$legacy_password"
}

read_ssh_password() {
    local prompt=${1:-"Enter SSH password: "}
    local password

    if [ ! -t 0 ]; then
        log_error "SSH password is required. Pass --ssh-password <password> in non-interactive mode."
        return 1
    fi

    read -r -s -p "$prompt" password
    echo

    if [ -z "$password" ]; then
        log_error "SSH password cannot be empty"
        return 1
    fi

    SSH_INPUT_PASSWORD="$password"
    return 0
}

resolve_ssh_port_for_start() {
    local port=$1
    local check_port=${2:-true}

    while true; do
        if [ -z "$port" ]; then
            if [ ! -t 0 ]; then
                log_error "SSH port is required. Pass --ssh-port <port> in non-interactive mode."
                return 1
            fi

            read -r -p "Enter SSH port, or press Enter to skip SSH: " port
            if [ -z "$port" ]; then
                SSH_RESOLVED_PORT=""
                return 0
            fi
        fi

        if ! validate_ssh_port "$port"; then
            if [ ! -t 0 ]; then
                return 1
            fi
            port=""
            continue
        fi

        if [ "$check_port" != "true" ] || ! ssh_port_in_use "$port"; then
            SSH_RESOLVED_PORT="$port"
            return 0
        fi

        log_error "SSH port $port is already in use on the host"
        if [ ! -t 0 ]; then
            log_error "Run again with --ssh-port <free-port>"
            return 1
        fi

        read -r -p "Enter a new SSH port, or press Enter to cancel: " port
        if [ -z "$port" ]; then
            log_info "Operation cancelled"
            return 1
        fi
    done
}

