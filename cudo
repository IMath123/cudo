    fi
    if [ "$show_gpu" = "true" ]; then
        args="$args --gpu"
    fi

    python3 "$python_script" $args
}

DOCTOR_FAIL_COUNT=0
DOCTOR_WARN_COUNT=0

doctor_pass() {
    echo "PASS  $1"
}

doctor_warn() {
    DOCTOR_WARN_COUNT=$((DOCTOR_WARN_COUNT + 1))
    echo "WARN  $1"
}

doctor_fail() {
    DOCTOR_FAIL_COUNT=$((DOCTOR_FAIL_COUNT + 1))
    echo "FAIL  $1"
}

doctor_command() {
    DOCTOR_FAIL_COUNT=0
    DOCTOR_WARN_COUNT=0

    echo "Cudo doctor"
    echo "Project: $PROJECT_ROOT"
    echo "Global config: $GLOBAL_CONFIG_DIR"
    echo

    if command -v docker > /dev/null 2>&1; then
        doctor_pass "docker command found: $(docker --version 2>/dev/null | head -1)"
        if docker info > /dev/null 2>&1; then
            doctor_pass "Docker daemon is available"
            if docker info --format '{{json .Runtimes}}' 2>/dev/null | grep -q 'nvidia'; then
                doctor_pass "NVIDIA Docker runtime is visible"
            else
                doctor_warn "NVIDIA Docker runtime was not found in docker info"
            fi
        else
            doctor_fail "Docker daemon is not available"
        fi
    else
        doctor_fail "docker command not found"
    fi

    if command -v docker > /dev/null 2>&1 && docker compose version > /dev/null 2>&1; then
        doctor_pass "Docker Compose v2 is available"
    elif command -v docker-compose > /dev/null 2>&1; then
        doctor_pass "docker-compose v1 is available"
    else
        doctor_fail "Docker Compose is not available"
    fi

    if command -v envsubst > /dev/null 2>&1; then
        doctor_pass "envsubst is available"
    else
        doctor_fail "envsubst is missing; install gettext"
    fi

    if command -v openssl > /dev/null 2>&1; then
        if openssl passwd -help 2>&1 | grep -q -- ' -6 '; then
            doctor_pass "openssl supports SHA-512 password hashes"
        else
            doctor_fail "openssl passwd does not support -6"
        fi
    else
        doctor_fail "openssl is missing"
    fi

    if [ -d "$GLOBAL_CONFIG_DIR" ]; then
        if [ -w "$GLOBAL_CONFIG_DIR" ]; then
            doctor_pass "Global config directory is writable"
        else
            doctor_fail "Global config directory is not writable: $GLOBAL_CONFIG_DIR"
        fi
    else
        local global_parent
        global_parent=$(dirname "$GLOBAL_CONFIG_DIR")
        if [ -d "$global_parent" ] && [ -w "$global_parent" ]; then
            doctor_warn "Global config directory does not exist yet; Cudo can create it when needed"
        else
            doctor_fail "Global config directory does not exist and parent is not writable: $GLOBAL_CONFIG_DIR"
        fi
    fi

    echo
    if [ -f "$CONFIG_FILE" ]; then
        local unique_hash=$(read_config_value "$CONFIG_FILE" "UNIQUE_HASH")
        local image_name=$(read_config_value "$CONFIG_FILE" "IMAGE_NAME")
        local ssh_port=$(read_config_value "$CONFIG_FILE" "SSH_PORT")
        local ssh_password_hash=$(read_config_value "$CONFIG_FILE" "SSH_PASSWORD_HASH_B64")
        local legacy_ssh_password=$(read_config_value "$CONFIG_FILE" "SSH_PASSWORD_B64")

        doctor_pass "Project config found: $CONFIG_FILE"

        if [ -n "$unique_hash" ]; then
            doctor_pass "Project unique hash: $unique_hash"
        else
            doctor_fail "Project config is missing UNIQUE_HASH"
        fi

        if [ -n "$image_name" ]; then
            if command -v docker > /dev/null 2>&1 && docker image inspect "$image_name" > /dev/null 2>&1; then
                doctor_pass "Docker image exists: $image_name"
            else
                doctor_warn "Docker image is not present locally: $image_name"
            fi
        else
            doctor_fail "Project config is missing IMAGE_NAME"
        fi

        if [ -n "$unique_hash" ] && command -v docker > /dev/null 2>&1 && docker info > /dev/null 2>&1; then
            local container_name="cuda-project-${unique_hash}-container"
            if docker ps -a --format '{{.Names}}' | grep -qx "$container_name"; then
                doctor_pass "Container exists: $container_name"
            else
                doctor_warn "Container does not exist yet: $container_name"
            fi
        fi

        if [ -n "$ssh_port" ]; then
            if validate_ssh_port "$ssh_port" > /dev/null 2>&1; then
                if ssh_port_in_use "$ssh_port"; then
                    doctor_warn "SSH port $ssh_port is currently in use"
                else
                    doctor_pass "SSH port $ssh_port is valid and available"
                fi
            else
                doctor_fail "SSH port is invalid: $ssh_port"
            fi
        else
            doctor_pass "SSH port is unset; no default port is configured"
        fi

        if [ -n "$ssh_password_hash" ]; then
            doctor_pass "SSH password is stored as a hash"
        elif [ -n "$legacy_ssh_password" ]; then
            doctor_warn "Legacy SSH_PASSWORD_B64 found; it will be migrated on next SSH configuration"
        elif [ -n "$ssh_port" ]; then
            doctor_warn "SSH port is set but SSH password hash is missing"
        else
            doctor_pass "SSH password is unset"
        fi
    else
        doctor_warn "No project config found in current directory"
    fi

    echo
    echo "Doctor summary: $DOCTOR_FAIL_COUNT fail(s), $DOCTOR_WARN_COUNT warning(s)"
    if [ "$DOCTOR_FAIL_COUNT" -gt 0 ]; then
        return 1
    fi
    return 0
}

# 显示用法
usage() {
    cat << EOF
Cudo - CUDA Development Environment Manager

Usage: cudo <command> [options]

Commands:
  build [options]    Build CUDA environment image
  run                Start and enter container
  enter [name]       Enter a Cudo environment from any directory
  rename <old> <new> Rename a Cudo environment
  status             Check container status
  start              Start container
  stop               Stop container
  commit             Save container state
  restart            Restart container (preserve state)
  restore            Restore container (restore to the last state)
  logs               View container logs
  remove             Delete container, image and configuration files
  config             Show current configuration
  list [options]     List all CUDA environments
  doctor             Diagnose Cudo dependencies and current project config
  cleanup            Clean up deleted/moved project configurations
  help               Show this help message

Build options:
  -c, --cuda-version     CUDA version (default: $DEFAULT_CUDA_VERSION)
  -u, --ubuntu-version   Ubuntu version (default: $DEFAULT_UBUNTU_VERSION)
  -t, --with-toolkit     Include CUDA Toolkit (flag, no value needed) (default: $DEFAULT_WITH_TOOLKIT)
  -p, --python-version   Python version (default: $DEFAULT_PYTHON_VERSION)
  -i, --image-name       Image name (default: based on project name)
  -n, --name             Environment name used by cudo enter

Runtime SSH options for run/start/enter:
      --ssh-port         Start SSH on the given host port
      --ssh-password     Password for SSH login

List options:
  -d, --details      Show detailed resource information (CPU, memory usage, etc.)
  -g, --gpu          Show GPU memory usage information

Examples:
  cudo build -c 11.8.0 -p 3.8
  cudo build --name train
  cudo run --ssh-port 2222 --ssh-password my-password
  ssh -p 2222 $USER@<host>
  cudo enter train --ssh-port 2223
  cudo enter train -- nvidia-smi
  cudo rename train training
  cudo commit
  cudo restore
  cudo restart
  cudo status
  cudo logs
  cudo config
  cudo list
  cudo list --details
  cudo doctor
  cudo cleanup
  cudo remove
EOF
}

# 主函数
main() {
    local command=$1
    shift

    case $command in
        "doctor"|"help"|"-h"|"--help"|""|"list"|"config")
            ;;
        *)
            update_global_status
            sync_global_env_names
            ;;
    esac

    case $command in
        "build")
            build_command "$@"
            ;;
        "run")
            run_command "$@"
            ;;
        "enter")
            enter_command "$@"
            ;;
        "rename")
            rename_command "$@"
            ;;
        "logs")
            logs_command "$@"
            ;;
        "remove")
            remove_command "$@"
            ;;
        "start")
            start_command "$@"
            ;;
        "stop")
            stop_command "$@"
            ;;
        "commit")
            commit_command "$@"
            ;;
        "restart")
            restart_command "$@"
            ;;
        "restore")
            restore_command "$@"
            ;;
        "status")
            status_command "$@"
            ;;
        "exec")
            run_command "$@"
            ;;
        "config")
            config_command
            ;;
        "list")
            local show_details=false
            local show_gpu=false
            while [[ $# -gt 0 ]]; do
                case $1 in
                    -d|--details)
                        show_details=true
                        shift
                        ;;
                    -g|--gpu)
                        show_gpu=true
                        shift
                        ;;
                    *)
                        shift
                        ;;
                esac
            done
            list_command "$show_details" "$show_gpu"
            ;;
        "doctor")
            doctor_command
            ;;
        "cleanup")
            cleanup_deleted_projects
            ;;
        "help"|"-h"|"--help"|"")
            usage
            ;;
        *)
            log_error "Unknown command: $command"
            usage
            exit 1
            ;;
    esac
}

# 运行主函数
main "$@"
