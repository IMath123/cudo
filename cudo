prepare_ssh_build_files() {
    cat > "$SSH_ENTRYPOINT_FILE" << 'EOF'
#!/bin/bash
set -e

load_cudo_ssh_config() {
    local config_file="/workspace/.cudo/config"

    CUDO_SSH_ENABLED="${CUDO_SSH_ENABLED:-false}"
    CUDO_SSH_PORT="${CUDO_SSH_PORT:-}"
    CUDO_SSH_USER="${CUDO_SSH_USER:-$(id -un)}"
    CUDO_SSH_PASSWORD_HASH_B64="${CUDO_SSH_PASSWORD_HASH_B64:-}"
    CUDO_SSH_PASSWORD_B64="${CUDO_SSH_PASSWORD_B64:-}"

    if [ -f "$config_file" ]; then
        CUDO_SSH_ENABLED=$(grep -m1 '^SSH_ENABLED=' "$config_file" | cut -d'=' -f2- || true)
        CUDO_SSH_PORT=$(grep -m1 '^SSH_PORT=' "$config_file" | cut -d'=' -f2- || true)
        CUDO_SSH_USER=$(grep -m1 '^SSH_USER=' "$config_file" | cut -d'=' -f2- || true)
        CUDO_SSH_PASSWORD_HASH_B64=$(grep -m1 '^SSH_PASSWORD_HASH_B64=' "$config_file" | cut -d'=' -f2- || true)
        CUDO_SSH_PASSWORD_B64=$(grep -m1 '^SSH_PASSWORD_B64=' "$config_file" | cut -d'=' -f2- || true)
    fi

    CUDO_SSH_ENABLED="${CUDO_SSH_ENABLED:-false}"
    CUDO_SSH_USER="${CUDO_SSH_USER:-$(id -un)}"
}

decode_base64_value() {
    local value=$1

    if base64 --help 2>&1 | grep -q -- '--decode'; then
        printf '%s' "$value" | base64 --decode
    elif base64 -d </dev/null >/dev/null 2>&1; then
        printf '%s' "$value" | base64 -d
    else
        printf '%s' "$value" | base64 -D
    fi
}

configure_cudo_ssh() {
    load_cudo_ssh_config

    if [ "$CUDO_SSH_ENABLED" != "true" ] || [ -z "$CUDO_SSH_PORT" ]; then
        return 0
    fi

    if [ -z "$CUDO_SSH_PASSWORD_HASH_B64" ] && [ -z "$CUDO_SSH_PASSWORD_B64" ]; then
        return 0
    fi

    if ! printf '%s' "$CUDO_SSH_PORT" | grep -Eq '^[0-9]+$'; then
        echo "Invalid Cudo SSH port: $CUDO_SSH_PORT" >&2
        exit 1
    fi

    local password_hash
    if [ -n "$CUDO_SSH_PASSWORD_HASH_B64" ]; then
        password_hash=$(decode_base64_value "$CUDO_SSH_PASSWORD_HASH_B64")
    else
        echo "Legacy Cudo SSH password config requires 'cudo run/start/enter --ssh-password' to migrate." >&2
        return 0
    fi

    sudo mkdir -p /run/sshd /etc/ssh/sshd_config.d
    if ! grep -q '^Include /etc/ssh/sshd_config.d/\*.conf' /etc/ssh/sshd_config; then
        printf '%s\n' 'Include /etc/ssh/sshd_config.d/*.conf' | sudo tee /tmp/cudo-sshd-include >/dev/null
        sudo sh -c 'cat /tmp/cudo-sshd-include /etc/ssh/sshd_config > /etc/ssh/sshd_config.cudo && mv /etc/ssh/sshd_config.cudo /etc/ssh/sshd_config'
        sudo rm -f /tmp/cudo-sshd-include
    fi

    printf '%s:%s\n' "$CUDO_SSH_USER" "$password_hash" | sudo chpasswd -e
    sudo tee /etc/ssh/sshd_config.d/cudo.conf >/dev/null << CONFIG_EOF
Port ${CUDO_SSH_PORT}
ListenAddress 0.0.0.0
PasswordAuthentication yes
ChallengeResponseAuthentication no
PubkeyAuthentication no
PermitRootLogin no
PermitEmptyPasswords no
AllowUsers ${CUDO_SSH_USER}
CONFIG_EOF

    sudo ssh-keygen -A > /dev/null 2>&1
    sudo /usr/sbin/sshd -t
    sudo pkill -x sshd >/dev/null 2>&1 || true
    sudo /usr/sbin/sshd -E /var/log/cudo-sshd.log
    echo "Cudo SSH is listening on port ${CUDO_SSH_PORT}"
}

configure_cudo_ssh

exec "$@"
EOF
    chmod 755 "$SSH_ENTRYPOINT_FILE"
}

update_ssh_runtime_config() {
    local project_path=$1
    local image_name=$2
    local unique_hash=$3
    local config_file=$4
    local requested_port=$5
    local requested_password=$6
    local password_provided=$7
    local check_port=$8

    local project_config_dir="$project_path/.cudo"
    local project_config_file="$project_config_dir/config"
    local global_config_file
    local current_port=$(read_config_value "$project_config_file" "SSH_PORT")
    local current_password_hash_b64=$(read_config_value "$project_config_file" "SSH_PASSWORD_HASH_B64")
    local current_password_b64=$(read_config_value "$project_config_file" "SSH_PASSWORD_B64")
    local current_user=$(read_config_value "$project_config_file" "SSH_USER")
    local password_hash_b64="$current_password_hash_b64"
    local port="${requested_port:-$current_port}"

    if [ -z "$current_user" ]; then
        current_user=$(id -un)
    fi

    if [ -z "$requested_port" ] && [ "$password_provided" != "true" ] && [ -z "$current_port" ] && [ -z "$current_password_hash_b64" ] && [ -z "$current_password_b64" ]; then
        return 0
    fi

    if ! resolve_ssh_port_for_start "$port" "$check_port"; then
        return 1
    fi
    port="$SSH_RESOLVED_PORT"

    if [ -z "$port" ]; then
        return 0
    fi

    if [ "$password_provided" = "true" ]; then
        if [ -z "$requested_password" ]; then
            log_error "SSH password cannot be empty"
            return 1
        fi
        if ! password_hash_b64=$(generate_ssh_password_hash_b64 "$requested_password"); then
            return 1
        fi
    elif [ -z "$password_hash_b64" ] && [ -n "$current_password_b64" ]; then
        if ! password_hash_b64=$(password_hash_from_legacy_b64 "$current_password_b64"); then
            return 1
        fi
        log_info "Migrated legacy SSH password storage to hash format"
    elif [ -z "$password_hash_b64" ]; then
        if ! read_ssh_password "Enter SSH password for $current_user: "; then
            return 1
        fi
        if ! password_hash_b64=$(generate_ssh_password_hash_b64 "$SSH_INPUT_PASSWORD"); then
            return 1
        fi
    fi

    set_config_value "$project_config_file" "SSH_ENABLED" "true"
    set_config_value "$project_config_file" "SSH_PORT" "$port"
    set_config_value "$project_config_file" "SSH_USER" "$current_user"
    set_config_value "$project_config_file" "SSH_PASSWORD_HASH_B64" "$password_hash_b64"
    remove_config_value "$project_config_file" "SSH_PASSWORD_B64"

    global_config_file="$config_file"
    if [ "$global_config_file" = "$project_config_file" ]; then
        global_config_file=$(get_global_config_for_hash "$unique_hash")
    fi

    if [ -n "$global_config_file" ] && [ -f "$global_config_file" ]; then
        set_config_value "$global_config_file" "SSH_ENABLED" "true"
        set_config_value "$global_config_file" "SSH_PORT" "$port"
        set_config_value "$global_config_file" "SSH_USER" "$current_user"
        set_config_value "$global_config_file" "SSH_PASSWORD_HASH_B64" "$password_hash_b64"
        remove_config_value "$global_config_file" "SSH_PASSWORD_B64"
    fi

    SSH_ENABLED=true
    SSH_PORT="$port"
    SSH_USER="$current_user"
    SSH_PASSWORD_HASH_B64="$password_hash_b64"
    SSH_PASSWORD_B64=""
    write_docker_compose_file "$project_config_dir/docker-compose.yml" "$image_name" "$unique_hash"
    SSH_RUNTIME_CONFIGURED=true
    log_info "SSH configured: user $current_user, port $port"
}

